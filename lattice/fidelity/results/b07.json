          "fields": {
            "amount": 500
          }
        }
      ]
    }
  },
  "humanVerdict": "faithful",
  "notes": "Rule TEXT over-claims (every invoice references...); expert intent is conditional (a ref, if present, resolves; null allowed). refsResolve implements the conditional reading, so it matches intent despite the letter."
