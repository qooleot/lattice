      "expected": "forbid",
      "state": {
        "entities": [
          {
            "type": "Invoice",
            "id": "inv2",
            "fields": {
              "subscription": "sub_missing"
            }
          }
        ]
      }
    },
    {
      "desc": "Two invoices both reference the same existing subscription",
      "expected": "permit",
      "state": {
        "entities": [
          {
            "type": "Subscription",
            "id": "sub2",
            "fields": {}
          },
          {
            "type": "Invoice",
            "id": "inv3",
            "fields": {
              "subscription": "sub2"
            }
          },
          {
            "type": "Invoice",
            "id": "inv4",
            "fields": {
              "subscription": "sub2"
            }
          }
        ]
      }
    }
