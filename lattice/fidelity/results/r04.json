      "state": {
        "entities": [
          { "type": "AccountingPeriod", "id": "P3", "fields": { "Lifecycle.state": "Open" } },
          { "type": "AccountingPeriod", "id": "P4", "fields": { "Lifecycle.state": "Closed" } },
          { "type": "RevenueEntry", "id": "R3", "fields": { "period": "P3", "amount": 300 } },
          { "type": "RevenueEntry", "id": "R4", "fields": { "period": "P4", "amount": 700 } }
        ]
      }
    }
  ],
