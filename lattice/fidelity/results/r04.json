      "state": {
        "entities": [
          { "type": "AccountingPeriod", "id": "P1", "fields": { "Lifecycle.state": "Open" } },
          { "type": "RevenueEntry", "id": "R1", "fields": { "period": "P1", "amount": 5000 } }
        ]
      }
    },
    {
      "desc": "Revenue entry posted to a period that has been closed",
