      "state": {
        "entities": [
          { "type": "AccountingPeriod", "id": "P2", "fields": { "Lifecycle.state": "Closed" } },
          { "type": "RevenueEntry", "id": "R2", "fields": { "period": "P2", "amount": 1200 } }
        ]
      }
    },
    {
      "desc": "Two revenue entries, one in an open period and one in a closed period",
