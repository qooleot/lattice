# Lattice: vendored solver artifacts (fetched locally, not committed)
lattice/vendor/*.jar
lattice/vendor/*.class
lattice/vendor/jdk

# Lattice: elicitation sessions & solver output. Unanchored on purpose — the elicit-spec skill
# runs the CLI from lattice/ with `--session ../.lattice-session-<slug>/`, so sessions land at the
# repo ROOT, which the old `lattice/`-anchored pattern never matched. Phase 0b scratch sessions go
# to mktemp -d and never land in the tree at all; the pattern below is a backstop for the ones that
# predate that, or that get pointed here by hand.
.lattice-session*/
.lattice-scratch*/

# ...except the two committed reference sessions, which are TRACKED and read directly by
# lattice/test/cli-apply.test.ts and lattice/test/dod.test.ts. Tracked files ignore .gitignore, so
# the pattern above never threatened what is already committed — but without these negations a NEW
# file added to either (a regenerated session gaining an artifact, say) would be silently dropped
# from the commit rather than reported as untracked.
!/.lattice-session-catalog/
!/.lattice-session-subscriptions/

lattice/_apalache-out/

# Tooling scratch
.superpowers/
